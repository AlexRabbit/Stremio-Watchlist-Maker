# Copy to /etc/nginx/sites-available/channel-organizer
# Replace YOUR_PUBLIC_HOSTNAME with your domain (never use a raw numeric host in public docs).

server {
    listen 443 ssl http2;
    server_name YOUR_PUBLIC_HOSTNAME;

    # ssl_certificate     /etc/letsencrypt/live/YOUR_PUBLIC_HOSTNAME/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/YOUR_PUBLIC_HOSTNAME/privkey.pem;

    client_max_body_size 64m;
    proxy_read_timeout 300s;
    proxy_send_timeout 300s;

    location / {
        proxy_pass http://127.0.0.1:7010;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

server {
    listen 80;
    server_name YOUR_PUBLIC_HOSTNAME;
    return 301 https://$host$request_uri;
}
