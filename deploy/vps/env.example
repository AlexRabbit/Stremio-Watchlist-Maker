HOST=127.0.0.1
PORT=7010
# Public HTTPS URL Stremio + GitHub Pages will use (your domain only):
BASE_URL=https://YOUR_PUBLIC_HOSTNAME

DATA_DIR=data
DB_PATH=data/playlists.db
LOG_DIR=logs
LOG_LEVEL=INFO

CINEMETA_BASE=https://v3-cinemeta.strem.io
METAHUB_POSTER=https://images.metahub.space/poster/medium

# GitHub Pages origin (comma-separated). Add your Pages URL host.
CORS_ORIGINS=https://alexrabbit.github.io

# Optional API lock (leave empty for open configure UI)
API_TOKEN=

IMPORT_WORKER_INTERVAL_SEC=2
IMPORT_BATCH_SIZE=5
IMPORT_RATE_LIMIT_PER_MIN=60
BACKUP_SCHEMA_VERSION=1
