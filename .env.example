# Stremio Playlists Addon — copy to .env and adjust
HOST=127.0.0.1
PORT=7010
BASE_URL=http://127.0.0.1:7010

# Database (portable — lives inside project folder)
DATA_DIR=data
DB_PATH=data/playlists.db

# Logging
LOG_DIR=logs
LOG_LEVEL=DEBUG
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Cinemeta (Stremio metadata — no key required)
CINEMETA_BASE=https://v3-cinemeta.strem.io
METAHUB_POSTER=https://images.metahub.space/poster/medium

# Optional TMDB for better search (leave empty to use Cinemeta only)
TMDB_API_KEY=

# Stremio local streaming server (legacy — install uses desktop launcher)
STREMIO_STREAMING_SERVER=http://127.0.0.1:11470

# Optional: override Stremio Desktop exe path
# STREMIO_EXE_PATH=C:\Users\You\AppData\Local\Programs\Stremio\stremio-shell-ng.exe

# Import worker
IMPORT_WORKER_INTERVAL_SEC=2
IMPORT_BATCH_SIZE=5
IMPORT_RATE_LIMIT_PER_MIN=30

# Optional: public API URL (Render). GitHub Actions injects this into the Pages build.
# PUBLIC_API_URL=https://stremio-channel-organizer.onrender.com

# CORS — GitHub Pages origin (comma-separated; * for dev)
CORS_ORIGINS=https://alexrabbit.github.io,*

# Backup format version
BACKUP_SCHEMA_VERSION=1
